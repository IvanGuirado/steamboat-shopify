{"layout":"password","sections":{"custom_liquid_PEbBjX":{"type":"custom-liquid","custom_css":[],"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- Google Fonts: Poppins -->\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .password-header, .password-login, .password__footer {\n    display: none !important;\n  }\n\n  html, body {\n    margin: 0 !important;\n    padding: 0 !important;\n    height: 100%;\n    background: none;\n    font-family: 'Poppins', sans-serif !important;\n  }\n\n  .launch-wrapper {\n    height: 100vh;\n    width: 100vw;\n    background: linear-gradient(135deg, #50CBCA, #000000);\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    padding: 2rem;\n    color: white;\n    text-align: center;\n    box-sizing: border-box;\n    text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.25);\n  }\n\n  .launch-wrapper img.logo {\n    max-width: 240px;\n    height: auto;\n    margin-bottom: 2.5rem;\n  }\n\n  .launch-wrapper h1 {\n    font-size: 2.2rem;\n    font-weight: 700;\n    color: #ffffff;\n    margin-bottom: 2rem;\n  }\n\n  .launch-wrapper p.message-line {\n    font-size: 1.3rem;\n    line-height: 1.8;\n    margin: 0.4rem 0;\n    color: #50CBCA;\n    font-weight: 500;\n  }\n\n  .cta-line {\n    font-size: 1.6rem;\n    font-weight: 700;\n    color: #ffffff;\n    margin-top: 1.5rem;\n  }\n\n  #countdown {\n    font-size: 1.6rem;\n    margin: 2.5rem 0 1.5rem;\n    font-weight: 600;\n    color: white;\n  }\n\n  .email-form {\n    display: flex;\n    border: 1px solid white;\n    border-radius: 6px;\n    overflow: hidden;\n    max-width: 400px;\n    width: 100%;\n    background: white;\n    margin-top: 0.5rem;\n  }\n\n  .email-form input[type=\"email\"] {\n    flex: 1;\n    padding: 0.75rem 1rem;\n    border: none;\n    outline: none;\n    font-size: 1rem;\n    color: black;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .email-form button {\n    background: transparent;\n    border: none;\n    padding: 0 1rem;\n    cursor: pointer;\n    font-size: 1.4rem;\n    font-weight: bold;\n    color: black;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .email-form button:hover {\n    background: rgba(0, 0, 0, 0.05);\n  }\n\n  #success-message {\n    margin-top: 1.2rem;\n    color: #50CBCA;\n    font-weight: 600;\n    display: none;\n    font-size: 1.1rem;\n  }\n\n  iframe.hidden-frame {\n    display: none;\n    width: 0;\n    height: 0;\n    border: 0;\n  }\n<\/style>\n\n<div class=\"launch-wrapper\">\n  <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0891\/7205\/0264\/files\/steam_boat-01.png?v=1754481490\" alt=\"Logo\" class=\"logo\">\n\n  <h1>Desde Mallorca con ruido<\/h1>\n\n  <p class=\"message-line\">Streetwear nacido entre sal, tinta y rebeldía.<\/p>\n  <p class=\"message-line\">Inspirado en la animación. Diseñado para romper.<\/p>\n  <p class=\"message-line\">Steamboat está por zarpar.<\/p>\n  <p class=\"cta-line\">¿Subes o te quedas en tierra?<\/p>\n\n  <div id=\"countdown\">Cargando...<\/div>\n\n  <!-- Formulario de suscripción -->\n  <form\n    method=\"POST\"\n    action=\"\/contact#contact_form\"\n    accept-charset=\"UTF-8\"\n    class=\"email-form\"\n    target=\"hidden_iframe\"\n  >\n    <input type=\"hidden\" name=\"form_type\" value=\"customer\">\n    <input type=\"hidden\" name=\"utf8\" value=\"✓\">\n    <input type=\"email\" name=\"contact[email]\" placeholder=\"Correo electrónico\" required>\n    <button type=\"submit\" aria-label=\"Enviar\">→<\/button>\n  <\/form>\n\n  <!-- iframe oculto -->\n  <iframe name=\"hidden_iframe\" class=\"hidden-frame\" id=\"hidden_iframe\"><\/iframe>\n\n  <div id=\"success-message\">✅ ¡Gracias! Te avisaremos pronto.<\/div>\n<\/div>\n\n<script>\n  \/\/ Fecha objetivo: hoy a las 18:00\n  const countdownDate = new Date();\n  countdownDate.setHours(18, 0, 0, 0); \/\/ 18:00:00\n\n  \/\/ Si ya pasó la hora, ponerlo para mañana a las 18:00\n  if (countdownDate.getTime() < Date.now()) {\n    countdownDate.setDate(countdownDate.getDate() + 1);\n  }\n\n  const targetTime = countdownDate.getTime();\n\n  \/\/ Cuenta atrás\n  const x = setInterval(function () {\n    const now = new Date().getTime();\n    const distance = targetTime - now;\n\n    if (distance < 0) {\n      clearInterval(x);\n      document.getElementById(\"countdown\").innerHTML = \"¡Ya hemos abierto!\";\n      return;\n    }\n\n    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) \/ (1000 * 60 * 60));\n    const minutes = Math.floor((distance % (1000 * 60 * 60)) \/ (1000 * 60));\n    const seconds = Math.floor((distance % (1000 * 60)) \/ 1000);\n\n    \/\/ Mostrar formato d h m s si quedan días, o solo h m s si es hoy\n    const days = Math.floor(distance \/ (1000 * 60 * 60 * 24));\n    if (days > 0) {\n      document.getElementById(\"countdown\").innerHTML =\n        days + \"d \" + hours + \"h \" + minutes + \"m \" + seconds + \"s \";\n    } else {\n      document.getElementById(\"countdown\").innerHTML =\n        hours + \"h \" + minutes + \"m \" + seconds + \"s \";\n    }\n  }, 1000);\n\n  \/\/ Mostrar mensaje de éxito cuando el iframe se carga tras el envío\n  document.getElementById('hidden_iframe').addEventListener('load', function () {\n    const form = document.querySelector('.email-form');\n    const success = document.getElementById('success-message');\n    \n    if (form.style.display !== 'none') {\n      form.style.display = 'none';\n      success.style.display = 'block';\n    }\n  });\n<\/script>","color_scheme":"","padding_top":0,"padding_bottom":0}},"main":{"type":"email-signup-banner","blocks":{"heading":{"type":"heading","settings":{"heading":"Nos vemos pronto...","heading_size":"h1"}},"paragraph":{"type":"paragraph","settings":{"text":"<p>Sé el primero en enterarte de todas las novedades<\/p>","text_style":"body"}},"email_form":{"type":"email_form","settings":{}}},"block_order":["heading","paragraph","email_form"],"disabled":true,"settings":{"image_overlay_opacity":0,"show_background_image":true,"image_height":"medium","desktop_content_position":"middle-center","show_text_box":true,"desktop_content_alignment":"center","color_scheme":"scheme-1","mobile_content_alignment":"center","show_text_below":true}}},"order":["custom_liquid_PEbBjX","main"]}
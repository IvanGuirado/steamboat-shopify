        "custom_liquid": "{% comment %} Guía de tallas dinámica con modal e idioma - Usa product.metafields.custom.style - Carga imagen ES o EN según el idioma activo - Botón y alt traducidos {% endcomment %}<style>.size-guide-container{text-align:center;}.size-guide-button{background:#4D4D4D;color:#fff;border:none;padding:10px 20px;font-size:14px;cursor:pointer;border-radius:5px;transition:background-color .3s ease;}.size-guide-button:hover{background:#333;}.size-guide-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);justify-content:center;align-items:center;z-index:9999;padding:20px;}.size-guide-content{background:#fff;padding:20px;border-radius:10px;max-width:900px;width:90%;position:relative;box-shadow:0 10px 40px rgba(0,0,0,.25);max-height:90vh;overflow:auto;}.size-guide-content img{width:100%;height:auto;cursor:zoom-in;transition:transform .3s ease;transform-origin:center center;}.size-guide-content img.zoomed{transform:scale(1.8);cursor:zoom-out;}.size-guide-close{position:absolute;top:12px;right:16px;font-size:24px;cursor:pointer;line-height:1;color:#333;}@media(max-width:768px){.size-guide-content img.zoomed{transform:scale(1.4);}}</style>{% assign estilo = product.metafields.custom.style.value | default: product.metafields.custom.style | strip %}{% assign idioma = request.locale.iso_code | downcase %}{% if idioma == 'en' %}{% assign sufijo_idioma = '-en' %}{% assign boton_texto = 'View size guide' %}{% assign alt_texto = 'Size guide' %}{% assign close_label = 'Close' %}{% else %}{% assign sufijo_idioma = '-es' %}{% assign boton_texto = 'Ver guía de tallas' %}{% assign alt_texto = 'Guía de tallas' %}{% assign close_label = 'Cerrar' %}{% endif %}{% if estilo != blank %}{% assign imagen_url = 'https://cdn.shopify.com/s/files/1/0891/7205/0264/files/' | append: estilo | append: sufijo_idioma | append: '.jpg' %}<div class=\"size-guide-container\"><button class=\"size-guide-button\" id=\"openSizeGuideBtn\" type=\"button\">{{ boton_texto }}</button></div><div id=\"sizeGuideModal\" class=\"size-guide-modal\" role=\"dialog\" aria-modal=\"true\" aria-label=\"{{ alt_texto }}\"><div class=\"size-guide-content\"><span class=\"size-guide-close\" id=\"closeSizeGuideBtn\" aria-label=\"{{ close_label }}\">&times;</span><img id=\"sizeGuideImage\" src=\"{{ imagen_url }}\" alt=\"{{ alt_texto }} - {{ estilo }}\" loading=\"lazy\"></div></div>{% endif %}<script>document.addEventListener('DOMContentLoaded',function(){var modal=document.getElementById('sizeGuideModal');var openBtn=document.getElementById('openSizeGuideBtn');var closeBtn=document.getElementById('closeSizeGuideBtn');var img=document.getElementById('sizeGuideImage');function closeModal(){if(modal)modal.style.display='none';if(img)img.classList.remove('zoomed');}if(openBtn&&modal){openBtn.addEventListener('click',function(){modal.style.display='flex';});}if(closeBtn){closeBtn.addEventListener('click',closeModal);}if(modal){modal.addEventListener('click',function(e){if(e.target===modal)closeModal();});}document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeModal();}});if(img){img.addEventListener('click',function(){img.classList.toggle('zoomed');});}});</script>",

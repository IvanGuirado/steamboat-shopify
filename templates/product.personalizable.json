            "custom_liquid": "<style>\n  .color-options-container {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    margin-top: 10px;\n  }\n\n  .color-label {\n    font-size: 1.3rem;\n    margin-bottom: 5px;\n  }\n\n  .color-options {\n    display: flex;\n    gap: 8px;\n    align-items: center;\n  }\n\n  .color-circle {\n    width: 18px;\n    height: 18px;\n    border-radius: 50%;\n    border: 1px solid #ccc;\n    display: inline-block;\n    cursor: pointer;\n  }\n\n  .color-circle.selected {\n    border: 2px solid black;\n    cursor: default;\n  }\n<\/style>\n\n{% assign related_colors = product.metafields.custom.colores_relacionados.value %}\n\n{% if related_colors != blank %}\n  <div class=\"color-options-container\">\n    <span class=\"color-label\">Color<\/span>\n    <div class=\"color-options\">\n      {% for related_product in related_colors %}\n        {% assign swatch_color = related_product.metafields.custom.color.value | default: related_product.metafields.custom.color %}\n\n        {% if swatch_color != blank %}\n          {% if related_product.id == product.id %}\n            <span\n              class=\"color-circle selected\"\n              style=\"background-color: {{ swatch_color }};\"\n              title=\"{{ related_product.title | escape }}\">\n            <\/span>\n          {% else %}\n            <a\n              class=\"color-circle js-color-link\"\n              href=\"{{ related_product.url }}\"\n              data-base-url=\"{{ related_product.url }}\"\n              style=\"background-color: {{ swatch_color }};\"\n              title=\"{{ related_product.title | escape }}\">\n            <\/a>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    <\/div>\n  <\/div>\n{% endif %}"

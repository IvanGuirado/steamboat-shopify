{%- comment -%}
  SECCIÓN VISUAL DE TODOS LOS DISEÑOS
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .steamboat-edit-designs-grid__title {
    margin: 0 0 2.4rem;
    text-align: center;
  }

  .steamboat-edit-designs-grid__items {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 3rem;
  }

  .steamboat-edit-designs-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .steamboat-edit-designs-grid__image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 28rem;
    margin-bottom: 0.8rem;
    text-decoration: none;
  }

  .steamboat-edit-designs-grid__image {
    display: block;
    width: 100%;
    max-width: 28rem;
    max-height: 28rem;
    height: auto;
    object-fit: contain;
    margin: 0 auto;
    transition: transform 0.25s ease;
  }

  .steamboat-edit-designs-grid__name {
    margin: 0 0 0.8rem;
    min-height: 4.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .steamboat-edit-designs-grid__link {
    display: inline-block;
    text-decoration: none;
  }

  .steamboat-edit-designs-grid__link .svg-wrapper,
  .steamboat-edit-designs-grid__link svg {
    margin-left: 0.6rem;
    transition: transform 0.25s ease;
  }

  .steamboat-edit-designs-grid_item:hover .steamboat-edit-designs-grid_image {
    transform: translateY(-4px);
  }

  .steamboat-edit-designs-grid_item:hover .steamboat-edit-designs-grid_link .svg-wrapper,
  .steamboat-edit-designs-grid_item:hover .steamboat-edit-designs-grid_link svg {
    transform: translateX(4px);
  }

  @media screen and (max-width: 989px) {
    .steamboat-edit-designs-grid__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.4rem 2rem;
    }

    .steamboat-edit-designs-grid__image-wrap {
      min-height: 26rem;
    }

    .steamboat-edit-designs-grid__image {
      max-height: 26rem;
    }
  }

  @media screen and (max-width: 749px) {
    .steamboat-edit-designs-grid__items {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .steamboat-edit-designs-grid__image-wrap {
      min-height: 28rem;
      margin-bottom: 0.8rem;
    }

    .steamboat-edit-designs-grid__image {
      max-width: 32rem;
      max-height: 28rem;
    }

    .steamboat-edit-designs-grid__name {
      min-height: auto;
      margin: 0 0 0.4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width steamboat-edit-designs-grid" id="disenos">
    <h2 class="title inline-richtext steamboat-edit-designs-grid__title">
      {{ 'steamboat_edit.designs.title' | t }}
    </h2>
    <div class="steamboat-edit-designs-grid__items">
      {%- assign choose_button_label = 'steamboat_edit.designs.choose_button' | t -%}

      {% render 'steamboat-edit-designs',
        mode: 'cards',
        product_url_es: section.settings.product_url_es,
        product_url_en: section.settings.product_url_en,
        default_placement: section.settings.default_placement,
        link_label: section.settings.link_label
      %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "SB Designs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "product_url_es",
      "default": "/products/steamboat-edit-blanca",
      "label": "URL producto ES"
    },
    {
      "type": "text",
      "id": "product_url_en",
      "default": "/en/products/steamboat-edit-white",
      "label": "URL producto EN"
    },
    {
      "type": "select",
      "id": "default_placement",
      "label": "Ubicación por defecto",
      "default": "front",
      "options": [
        { "value": "front", "label": "Front" },
        { "value": "back", "label": "Back" },
        { "value": "", "label": "Sin parámetro" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Relleno superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Relleno inferior",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "SB Designs"
    }
  ]
}
{% endschema %}

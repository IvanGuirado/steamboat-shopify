{% comment %}
  =========================================================
  STEAMBOAT EDIT LANDING
  Landing bilingüe para la página de personalización.
  Todos los textos salen de locales/*.json con | t
  =========================================================
{% endcomment %}
{{ 'section-steamboat-edit-landing.css' | asset_url | stylesheet_tag }}
<section class="steamboat-edit-landing page-width">
  <div class="steamboat-edit-landing__hero">
    <h1>{{ 'configura_prenda.hero_title' | t }}</h1>
    <div class="steamboat-edit-landing__intro rte">
      <p>{{ 'configura_prenda.hero_text' | t }}</p>
    </div>
  </div>

  <div class="steamboat-edit-landing__steps">
    <div class="steamboat-edit-landing__step">
      <h3>{{ 'configura_prenda.step_1_title' | t }}</h3>
      <p>{{ 'configura_prenda.step_1_text' | t }}</p>
    </div>

    <div class="steamboat-edit-landing__step">
      <h3>{{ 'configura_prenda.step_2_title' | t }}</h3>
      <p>{{ 'configura_prenda.step_2_text' | t }}</p>
    </div>

    <div class="steamboat-edit-landing__step">
      <h3>{{ 'configura_prenda.step_3_title' | t }}</h3>
      <p>{{ 'configura_prenda.step_3_text' | t }}</p>
    </div>
  </div>

  <div class="steamboat-edit-landing__cta">
    <a href="{{ section.settings.configure_link }}" class="button button--primary">
      {{ 'configura_prenda.cta_configure' | t }}
    </a>
  </div>

  <div class="steamboat-edit-landing__predefined">
    <div class="steamboat-edit-landing__predefined-image">
      {% if section.settings.predefined_image != blank %}
        {%- assign predefined_alt = 'configura_prenda.predefined_title' | t -%}
        {{
          section.settings.predefined_image
          | image_url: width: 900
          | image_tag: loading: 'lazy', alt: predefined_alt
        }}
      {% endif %}
    </div>

    <div class="steamboat-edit-landing__predefined-content">
      <h2>{{ 'configura_prenda.predefined_title' | t }}</h2>
      <div class="rte">
        <p>{{ 'configura_prenda.predefined_text' | t }}</p>
      </div>

      <a href="{{ section.settings.predefined_link }}" class="button button--secondary">
        {{ 'configura_prenda.cta_view_options' | t }}
      </a>
    </div>
  </div>

  <div class="steamboat-edit-landing__designs">
    <h2>{{ 'configura_prenda.available_designs' | t }}</h2>

    <div class="steamboat-edit-landing__design-grid">
      {% for block in section.blocks %}
        <div class="steamboat-edit-landing__design-card" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: section.settings.configure_link }}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% endif %}
            {% if block.settings.title != blank %}
              <p>{{ block.settings.title }}</p>
            {% endif %}
          </a>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.more_designs_link != blank %}
      <div class="steamboat-edit-landing__designs-footer">
        <a href="{{ section.settings.more_designs_link }}" class="button button--secondary">
          {{ 'configura_prenda.cta_view_more' | t }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Steamboat Edit landing",
  "settings": [
    {
      "type": "url",
      "id": "configure_link",
      "label": "Enlace botón configurar"
    },
    {
      "type": "image_picker",
      "id": "predefined_image",
      "label": "Imagen personalización predefinida"
    },
    {
      "type": "url",
      "id": "predefined_link",
      "label": "Enlace botón personalización predefinida"
    },
    {
      "type": "url",
      "id": "more_designs_link",
      "label": "Enlace ver más diseños"
    }
  ],
  "blocks": [
    {
      "type": "design",
      "name": "Diseño",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre del diseño"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Steamboat Edit landing"
    }
  ]
}
{% endschema %}

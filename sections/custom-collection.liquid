<style>
    .collection-title {
      font-size: 16px;
      font-weight: bold;
      text-transform: uppercase;
    }

    /* Filtro de ordenación */

    .featured-products {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin: 0 auto;
      padding: 0 20px;
      width: 100%;
      max-width: 100vw;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: left;
      position: relative;
      width: 100%;
    }

    .product-image-container {
      width: 100%;
      aspect-ratio: 1/1.4;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      background-color: #e0e0e0;
    }

    /*Fondo semi-transparente en productos agotados*/
    .product-image-container.sold-out::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(247, 247, 247, 0.63); /* Fondo translúcido */
      z-index: 2;
    }

    .product-image-container img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: opacity 0.3s ease-in-out;
    }

    .product-image-container .hover-image {
      object-fit: cover;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
    }

    .product-card:hover .hover-image {
      opacity: 1;
    }

    /*Etiqueta "AGOTADO" en el centro*/
    .out-of-stock-label {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background-color: rgba(0, 0, 0, 0.8);
      color: white;
      font-size: 14px;
      font-weight: bold;
      padding: 8px 15px;
      text-transform: uppercase;
      border-radius: 5px;
      z-index: 3;
    }

    .product-info {
      width: 100%;
      text-align: left;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding: 0;
      margin: 0;
    }

    .product-title {
      font-size: 14px;
      font-weight: bold;
      text-transform: uppercase;
      margin: 0px;
      transition: opacity 0.3s ease-in-out;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 90%;
      letter-spacing: 0rem;
    }

    .product-price {
      font-size: 14px;
      color: #333;
      margin: 0px;
      transition: opacity 0.3s ease-in-out;
    }

    /* Ocultar título, precio y swatches al hacer hover */
    .product-card:hover .product-title,
    .product-card:hover .product-price,
    .product-card:hover .color-options {
      opacity: 0;
    }

    .color-options {
      display: flex;
      gap: 5px;
      margin-top: 0px;
      margin-bottom: 15px;
      transition: opacity 0.3s ease-in-out;
    }

    .color-circle {
      width: 13px;
      height: 13px;
      border-radius: 50%;
      border: 1px solid #ccc;
      display: inline-block;
      background-size: cover;
      cursor: pointer;
    }

    .color-circle.selected {
      border: 1px solid black;
      cursor: default;
    }

    .sizes {
      font-size: 12px;
      font-weight: bold;
      display: flex;
      justify-content: center;
      gap: 8px;
      width: 100%;
      opacity: 0;
      position: absolute;
      bottom: 10px;
      left: 50%;
      transform: translateX(-50%);
    }

    .product-card:hover .sizes {
      opacity: 1;
      bottom: 40px;
    }

    .sizes span.out-of-stock {
      text-decoration: line-through;
      color: gray;
    }
    @media (min-width: 990px) and (max-width: 1199px) {}


  

    @media (min-width: 750px) and (max-width: 989px) {
    .featured-products {
      grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
      gap: 1.2rem !important;
    }

    .featured-products .product-card {
      width: 100% !important;
      max-width: 100% !important;
      min-width: 0 !important;
      margin: 0 !important;
    }

    .featured-products .product-info {
      min-height: 92px;
      margin-top: 0.7rem;
    }

    .featured-products .product-info h3,
    .featured-products .product-info .product-title,
    .featured-products .product-info a {
      font-size: 1.35rem !important;
      line-height: 1.3 !important;
    }

    .featured-products .product-info p,
    .featured-products .product-info .price {
      font-size: 1.2rem !important;
      line-height: 1.3 !important;
      margin-top: 0.25rem !important;
    }
  }

  @media (min-width: 600px) and (max-width: 749px) {
  .featured-products {
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: 1rem !important;
  }

  .featured-products .product-card {
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    margin: 0 !important;
  }

  .featured-products .product-info {
    min-height: 88px;
    margin-top: 0.6rem;
  }

  .featured-products .product-info h3,
  .featured-products .product-info .product-title,
  .featured-products .product-info a {
    font-size: 1.3rem !important;
    line-height: 1.3 !important;
  }

  .featured-products .product-info p,
  .featured-products .product-info .price {
    font-size: 1.15rem !important;
    line-height: 1.3 !important;
    margin-top: 0.2rem !important;
  }
}

    @media (max-width: 390px) {
    .featured-products {
      grid-template-columns: repeat(1, 1fr) !important;
    }
  }
  @media (min-width: 391px) and (max-width: 599px) {
    .featured-products {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }
</style>

<section>
  <div class="section-header-featured">
    <div class="collection-title">
      {{ collection.title }}
    </div>

    <div class="filter-container">
      <span class="filter-label">{{ 'collections.sorting.label' | t }}</span>

      {% assign current_sort = collection.sort_by | default: collection.default_sort_by %}

      <div class="filter-select">
        <span>
          {% case current_sort %}
            {% when 'manual' %}
              {{ 'collections.sorting.featured' | t }}
            {% when 'best-selling' %}
              {{ 'collections.sorting.best_selling' | t }}
            {% when 'created-descending' %}
              {{ 'collections.sorting.newest' | t }}
            {% when 'price-ascending' %}
              {{ 'collections.sorting.price_ascending' | t }}
            {% when 'price-descending' %}
              {{ 'collections.sorting.price_descending' | t }}
            {% else %}
              {{ 'collections.sorting.featured' | t }}
          {% endcase %}
          ▾
        </span>

        <div class="filter-dropdown">
          <a href="?sort_by=manual">{{ 'collections.sorting.featured' | t }}</a>
          <a href="?sort_by=best-selling">{{ 'collections.sorting.best_selling' | t }}</a>
          <a href="?sort_by=created-descending">{{ 'collections.sorting.newest' | t }}</a>
          <a href="?sort_by=price-ascending">{{ 'collections.sorting.price_ascending' | t }}</a>
          <a href="?sort_by=price-descending">{{ 'collections.sorting.price_descending' | t }}</a>
        </div>
      </div>
    </div>
  </div>

  <div class="featured-products">
    {% for product in collection.products %}
      {% unless product.tags contains 'hidden-customizer' %}
      {% assign total_stock = 0 %}
      {% for variant in product.variants %}
        {% assign total_stock = total_stock | plus: variant.inventory_quantity %}
      {% endfor %}

      <div class="product-card">
        <a href="{{ product.url }}">
          <div class="product-image-container {% if total_stock == 0 %}sold-out{% endif %}">
            {% if total_stock == 0 %}
              <div class="out-of-stock-label">AGOTADO</div>
            {% endif %}
            <img class="main-image" src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}">
            {% if product.images[1] %}
              <img class="hover-image" src="{{ product.images[1] | img_url: '800x' }}" alt="Hover Image">
            {% endif %}
          </div>
        </a>
        <div class="product-info">
          <p class="product-title">{{ product.title }}</p>
          <p class="product-price">{{ product.price | money }}</p>

          <div class="color-options">
            {% assign product_color_group = product.metafields.custom.color_group %}

            {% if product_color_group %}
              {% for related_product in collections.all.products %}
                {% if related_product.metafields.custom.color_group == product_color_group %}
                  {% assign swatch_color = related_product.metafields.custom.color %}

                  {% if related_product.id == product.id %}
                    <span
                      class="color-circle selected"
                      style="background-color: {{ swatch_color }};"
                      title="{{ related_product.title }}"
                    >
                    </span>
                  {% else %}
                    <a
                      class="color-circle"
                      href="{{ related_product.url }}"
                      style="background-color: {{ swatch_color }};"
                      title="{{ related_product.title }}"
                    >
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>

          <div class="sizes">
            {% for variant in product.variants %}
              {% if variant.inventory_quantity > 0 %}
                <span>{{ variant.option1 }}</span>
              {% else %}
                <span class="out-of-stock">{{ variant.option1 }}</span>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      {% endunless %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [],
  "presets": [
    {
      "name": "Collection Grid",
      "category": "Collection"
    }
  ]
}
{% endschema %}

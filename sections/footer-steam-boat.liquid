    },
    {
      "type": "text",
      "id": "legal_notice",
      "label": "Texto Aviso Legal",
      "default": "AVISO LEGAL"
    },
    {
      "type": "text",
      "id": "privacy_policy",
      "label": "Texto Política de Privacidad",
      "default": "POLÍTICA DE PRIVACIDAD"
    },
    {
      "type": "text",
      "id": "terms",
      "label": "Texto Términos",
      "default": "TÉRMINOS"
    },
    {
      "type": "text",
      "id": "support_title",
      "label": "Título de Soporte",
      "default": "SOPORTE"
    },
    {
      "type": "text",
      "id": "returns",
      "label": "Texto Devoluciones",
      "default": "DEVOLUCIONES"
    },
    {
      "type": "text",
      "id": "faq",
      "label": "Texto FAQ",
      "default": "FAQ's"
    },
    {
      "type": "text",
      "id": "contact",
      "label": "Texto Contacto",
      "default": "CONTACTO"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Título Newsletter",
      "default": "ÚNETE AL CLUB"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Texto Newsletter",
      "default": "SUSCRÍBETE A NUESTRA NEWSLETTER"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Placeholder Newsletter",
      "default": "Email address"
    },
    {
      "type": "text",

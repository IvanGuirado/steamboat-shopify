<style>
.hero-slider {
  position: relative;
  overflow: hidden;
  margin-bottom: 0;
}
.hero-slide-link {
  text-decoration: none;
  color: inherit;
  display: block;
  width: 100%;
  height: 100%;
}
.hero-slide-link:hover {
  cursor: pointer;
}
.hero-slide {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 0;
}
.hero-slide img {
  width: 100%;
  height: auto;
  object-fit: contain;
  object-position: top center;
  display: none;
}
.desktop-image,
.mobile-image {
  display: none;
}
@media screen and (min-width: 750px) {
  .desktop-image {
    display: block !important;
  }
}
@media screen and (max-width: 749px) {
  .mobile-image {
    display: block !important;
  }
}

.hero-slide-content {
  position: absolute;
  z-index: 2;
  text-align: center;
  padding: 20px 30px;
  border-radius: 8px;
}

/* Estilo título */
.hero-slide h2 {
  margin-bottom: 2rem;
  line-height: 1.2;
}

/* Posiciones de contenido */
.top-center {
  align-items: flex-start;
  justify-content: center;
}
.center-center {
  align-items: center;
  justify-content: center;
}
.bottom-center {
  align-items: flex-end;
  justify-content: center;
}
.top-left {
  align-items: flex-start;
  justify-content: flex-start;
}
.center-left {
  align-items: center;
  justify-content: flex-start;
}
.bottom-left {
  align-items: flex-end;
  justify-content: flex-start;
}
.top-right {
  align-items: flex-start;
  justify-content: flex-end;
}
.center-right {
  align-items: center;
  justify-content: flex-end;
}
.bottom-right {
  align-items: flex-end;
  justify-content: flex-end;
}

/* Paginación Swiper */
.swiper-pagination {
  position: absolute;
  bottom: 30px;
  left: 0;
  right: 0;
  width: 100%;
  text-align: center;
  z-index: 20;
  display: flex;
  justify-content: center;
  gap: 10px;
}
.swiper-pagination-bullet {
  width: 12px;
  height: 12px;
  background: white;
  opacity: 0.5;
  border-radius: 50%;
  display: inline-block;
  transition: opacity 0.3s, transform 0.3s;
}
.swiper-pagination-bullet-active {
  opacity: 1;
  transform: scale(1.3);
}
@media screen and (max-width: 749px) {
  .swiper-pagination {
    bottom: 15px;
  }
}
</style>

<div class="hero-slider swiper">
  <div class="swiper-wrapper">
    {% for block in section.blocks %}
      {% assign bg_color = block.settings.text_bg_color | remove: "#" %}
      {% assign r = bg_color | slice: 0, 2 | prepend: "0x" | times: 1 %}
      {% assign g = bg_color | slice: 2, 2 | prepend: "0x" | times: 1 %}
      {% assign b = bg_color | slice: 4, 2 | prepend: "0x" | times: 1 %}

      <div class="hero-slide swiper-slide {{ block.settings.text_position }}">
        <a href="{{ block.settings.cta_link }}" class="hero-slide-link">
          {% if block.settings.image_desktop %}
            <img src="{{ block.settings.image_desktop | img_url: 'master' }}" class="desktop-image" alt="">
          {% endif %}
          {% if block.settings.image_mobile %}
            <img src="{{ block.settings.image_mobile | img_url: 'master' }}" class="mobile-image" alt="">
          {% endif %}
          <div class="hero-slide-content" style="background-color: rgba({{ r }}, {{ g }}, {{ b }}, {{ block.settings.text_bg_opacity }}); font-family: {{ block.settings.font_family }};">
            {% if block.settings.title != blank %}
              <h2 style="color: {{ block.settings.title_color }}; font-size: {{ block.settings.title_font_size }}px;">
                {{ block.settings.title }}
              </h2>
            {% endif %}
          </div>
        </a>
      </div>
    {% endfor %}
  </div>

  <div class="swiper-pagination"></div>
</div>

<script>
  var swiper = new Swiper('.swiper', {
    loop: true,
    autoplay: {
      delay: 5000,
    },
    effect: 'fade',
    fadeEffect: {
      crossFade: true
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true
    }
  });
</script>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Imagen para escritorio"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Imagen para móvil"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "Enlace del slide"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider"
    }
  ]
}
{% endschema %}

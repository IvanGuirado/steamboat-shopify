{%- comment -%}
  STEAMBOAT EDIT DESIGNS

  Uso:
  - JSON para JS:
    {% render 'steamboat-edit-designs', mode: 'json' %}

  - options para el select:
    {% render 'steamboat-edit-designs', mode: 'options' %}

  - cards para la rejilla:
    {% render 'steamboat-edit-designs', mode: 'cards', product_url: section.settings.product_url, default_placement: section.settings.default_placement, link_label: section.settings.link_label %}
{%- endcomment -%}

